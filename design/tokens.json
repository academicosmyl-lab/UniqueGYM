{
  "$nombre": "Unique Gym — Design Tokens",
  "$marca": "Forma tu cuerpo",
  "$nota_color": "Verde, plata y negro extraídos DIRECTO del logo oficial (pixel-exactos).",
  "color": {
    "verde":        "#1DDE10",
    "verde_claro":  "#4DFF3A",
    "verde_dim":    "#149A0B",
    "negro":        "#050505",
    "superficie":   "#101312",
    "superficie_2": "#171B19",
    "superficie_3": "#1F2522",
    "plata_1":      "#F5F5F5",
    "plata_2":      "#DCDCDC",
    "plata_3":      "#9A9A9A",
    "texto":        "#EDEFEE",
    "apagado":      "#8A938E",
    "linea":        "rgba(255,255,255,0.08)",
    "azul_agua":    "#3A7DE0",
    "ambar_alerta": "#E0A13F",
    "rojo_error":   "#E0653F"
  },
  "$colores_funcionales": "azul_agua, ambar_alerta y rojo_error NO son de marca; son colores de interfaz (hidratación, advertencias, errores). Cámbialos si quieres todo estrictamente de marca.",
  "gradiente_plata": "linear-gradient(160deg, #F5F5F5, #DCDCDC 45%, #9A9A9A 100%)",
  "tipografia": {
    "display": { "familia": "Saira Condensed, DejaVu Sans Condensed, sans-serif", "estilo": "italic", "peso": 800 },
    "texto":   { "familia": "Inter, DejaVu Sans, sans-serif", "peso": 400 },
    "datos":   { "familia": "Saira, DejaVu Sans, sans-serif", "peso": 700 },
    "escala_px": { "h1": 26, "h2": 20, "h3": 16, "cuerpo": 14, "pequeno": 12, "micro": 10 }
  },
  "radio_px": { "sm": 8, "md": 12, "lg": 16, "xl": 20, "pill": 999 },
  "espaciado_px": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 24, "2xl": 32 },
  "sombra": {
    "verde_glow": "0 0 24px rgba(29,222,16,0.35)",
    "tarjeta": "0 30px 60px -30px rgba(0,0,0,0.8)"
  },
  "rango_estado": { "saludable": "#1DDE10", "advertencia": "#E0A13F", "fuera": "#E0653F", "info": "#3A7DE0" }
}
